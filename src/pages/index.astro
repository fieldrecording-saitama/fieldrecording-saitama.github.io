---
import AboutContent from "../content/about.md";
import EventContent from "../content/event.md";
import ListeningNotes from "../content/listening-notes.md";

const pageTitle = "サウンド・コミュニケーション・ウォークさいたま2026 | フィールドレコーディングクラブさいたま";
const pageDescription = "2026年7月18日・19日に同一内容で各日開催。参加はどちらか1日を選ぶ、フィールドレコーディングクラブさいたまのサウンドウォークです。";
const siteUrl = "https://fieldrecording-saitama.github.io/";
const ogImage = `${siteUrl}assets/img/ogp-fieldrecording-saitama.jpg`;

const projectSteps = [
  {
    number: "01",
    title: "世界リスニングデーイベント",
    body: "7月18日・19日に同じ内容で各日開催。大宮駅前から氷川参道、氷川神社、大宮公園へ、「聴くこと」を通して音風景を探索します。",
  },
  {
    number: "02",
    title: "録音ワークショップ",
    body: "大宮駅東口、氷川参道、その周辺をフィールドに録音します。",
  },
  {
    number: "03",
    title: "成果展示発表会",
    body: "音源、地図、写真、映像、サウンド・インスタレーションを組み合わせて展示します。",
  },
  {
    number: "04",
    title: "Webアーカイブ化",
    body: "録音地点、メモ、写真を整理し、さいたまの音風景として残します。",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://fieldrecording-saitama.github.io/#website",
      url: siteUrl,
      name: "フィールドレコーディングクラブさいたま",
      inLanguage: "ja",
      description: "さいたまの音風景を記録し、展示やWebアーカイブとして発信する市民クラブのWebサイト。",
    },
    {
      "@type": "Organization",
      "@id": "https://fieldrecording-saitama.github.io/#organization",
      name: "フィールドレコーディングクラブさいたま",
      alternateName: "Field Recording Club Saitama",
      url: siteUrl,
      sameAs: [
        "https://www.instagram.com/fieldrecording_saitama",
        "https://www.facebook.com/groups/800702228957228/",
      ],
    },
    {
      "@type": "Event",
      "@id": "https://fieldrecording-saitama.github.io/#sound-communication-walk-2026",
      name: "サウンド・コミュニケーション・ウォークさいたま2026",
      description: "フィールドレコーディングクラブさいたまと歩く、大宮の音風景を探索するサウンドウォークです。2026年7月18日と19日に同一内容で各日開催し、参加者はいずれか1日を選んで参加します。",
      startDate: "2026-07-18T16:00:00+09:00",
      endDate: "2026-07-19T19:00:00+09:00",
      eventStatus: "https://schema.org/EventScheduled",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      image: [ogImage],
      url: "https://soundwalk-saitama2026-7.peatix.com/",
      isAccessibleForFree: false,
      location: {
        "@type": "Place",
        name: "まちラボおおみや / URBAN DESIGN CENTER OMIYA",
        address: {
          "@type": "PostalAddress",
          streetAddress: "宮町一丁目60番地 大宮ラクーン8F",
          addressLocality: "さいたま市大宮区",
          addressRegion: "埼玉県",
          addressCountry: "JP",
        },
      },
      organizer: {
        "@id": "https://fieldrecording-saitama.github.io/#organization",
      },
      performer: [
        {
          "@type": "Organization",
          name: "Field Recording Club, Saitama",
        },
        {
          "@type": "Person",
          name: "Minuma / Nukumori Eugene",
        },
      ],
      offers: {
        "@type": "Offer",
        url: "https://soundwalk-saitama2026-7.peatix.com/",
        price: "1000",
        priceCurrency: "JPY",
        availability: "https://schema.org/InStock",
        validFrom: "2026-06-18T00:00:00+09:00",
      },
    },
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:site_name" content="フィールドレコーディングクラブさいたま" />
    <meta property="og:title" content="サウンド・コミュニケーション・ウォークさいたま2026" />
    <meta property="og:description" content="7月18日・19日に同じ内容で各日開催。参加はどちらか1日。大宮の音風景を探索するサウンドウォークです。" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="フィールドレコーディングクラブさいたま公式HPのOGP画像" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="サウンド・コミュニケーション・ウォークさいたま2026" />
    <meta name="twitter:description" content="7月18日・19日に同じ内容で各日開催。参加はどちらか1日。大宮駅前から大宮公園へ歩き、音風景を探索します。" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="フィールドレコーディングクラブさいたま公式HPのOGP画像" />
    <meta name="theme-color" content="#24483e" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/assets/vendor/maplibre/maplibre-gl.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="site-header" aria-label="サイトヘッダー">
      <a class="brand" href="#top" aria-label="フィールドレコーディングクラブさいたま ホーム">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>FRCS</span>
      </a>
      <nav class="site-nav" aria-label="主要ナビゲーション">
        <a href="#about">About</a>
        <a href="#event">Event</a>
        <a href="#sound-map">Sound Map</a>
        <a href="#program">Program</a>
        <a href="#join">Join</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <span class="hero-slide hero-slide-1"></span>
          <span class="hero-slide hero-slide-2"></span>
          <span class="hero-slide hero-slide-3"></span>
          <span class="hero-slide hero-slide-4"></span>
          <span class="hero-slide hero-slide-5"></span>
        </div>
        <div class="hero-overlay" aria-hidden="true"></div>
        <div class="hero-ornaments" aria-hidden="true">
          <span>35.906 N / 139.624 E</span>
          <span>OMIYA - HIKAWA - MINUMA</span>
        </div>
        <div class="hero-content">
          <p class="eyebrow">Field Recording Club Saitama</p>
          <div class="hero-event" aria-label="Peatixで参加申込み受付中。7月18日または19日のどちらか1日を選んで参加">
            <span>Peatixで日程を選んで申込み受付中</span>
            <strong>サウンド・<wbr />コミュニケーション・<wbr /><span class="text-keep">ウォークさいたま2026</span></strong>
          </div>
          <h1 id="hero-title">耳をひらくと、<br />さいたまは<br />別の風景になる。</h1>
          <p class="hero-copy">
            World Listening Day関連企画。同じ内容のサウンドウォークを7月18日（土）・19日（日）に各日開催します。参加はどちらか1日。<span class="text-keep">フィールドレコーディング</span><wbr /><span class="text-keep">クラブさいたま</span>と、都市の喧騒から自然の静寂へ、五感で音風景をたどります。
          </p>
          <div class="hero-actions" aria-label="ページ内リンク">
            <a class="button primary accent" href="https://soundwalk-saitama2026-7.peatix.com/" target="_blank" rel="noopener">参加日を選んで申込む</a>
            <a class="button" href="#event">詳細を見る</a>
          </div>
          <p class="hero-apply-note">2026年7月18日（土）・19日（日）16:00〜19:00（15:30受付開始予定） / 両日同一内容・参加はどちらか1日 / 各日定員10名程度・参加費1000円（当日払い / 小中学生無料） / 雨天決行</p>
          <div class="hero-actions secondary" aria-label="補助リンク">
            <a class="button ghost" href="#join">活動をフォローする</a>
          </div>
        </div>
        <div class="hero-date-card hero-date-card-range" aria-label="2026年7月18日土曜日と19日日曜日に同一内容で開催。参加はどちらか1日">
          <span>Sound Communication Walk<br />Pick One Day</span>
          <em>2026</em>
          <div class="hero-date-days" aria-hidden="true">
            <div class="hero-date-day">
              <strong>7.18</strong>
              <b>SAT</b>
            </div>
            <div class="hero-date-day">
              <strong>7.19</strong>
              <b>SUN</b>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="section section-grid">
        <div>
          <p class="section-kicker">About</p>
          <h2>フィールドレコーディング<br /><span class="text-keep">クラブさいたまとは</span></h2>
        </div>
        <div class="prose">
          <AboutContent />
        </div>
      </section>

      <section id="event" class="section event-section" aria-labelledby="event-title">
        <div class="event-copy markdown-content">
          <EventContent />
          <div class="event-actions">
            <a class="button primary accent" href="https://soundwalk-saitama2026-7.peatix.com/" target="_blank" rel="noopener">参加日を選んで申込む</a>
          </div>
        </div>
      </section>

      <section id="project" class="section muted">
        <div class="section-heading">
          <p class="section-kicker">Project</p>
          <h2>さいたまの音風景<br /><span class="text-keep">録音ワークショップ</span>＆<span class="text-keep">成果展示発表会</span></h2>
        </div>
        <div class="project-flow" aria-label="今年度事業の流れ">
          {projectSteps.map((step) => (
            <article>
              <span>{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
        <div class="project-support" aria-label="助成情報">
          <p>
            本事業は、
            <a href="https://artscouncil-saitama.jp/grants/information/r8joseikin/" target="_blank" rel="noopener">アーツカウンシルさいたま文化芸術都市創造助成事業</a>
            の採択事業です。
          </p>
          <a class="project-support-logo" href="https://artscouncil-saitama.jp/grants/information/r8joseikin/" target="_blank" rel="noopener" aria-label="アーツカウンシルさいたま公式サイト">
            <img src="/assets/img/arts-council-saitama-logo.png" alt="アーツカウンシルさいたま" loading="lazy" />
          </a>
        </div>
      </section>

      <section id="sound-map" class="section sound-section" aria-labelledby="sound-map-title">
        <div class="section-heading compact">
          <p class="section-kicker">Sound Map</p>
          <h2 id="sound-map-title">さいたまの音地図</h2>
          <p>地図上の録音地点を選ぶと、Livingroom TapesのSoundCloud音源と録音メモが切り替わります。</p>
        </div>
        <div class="sound-map-shell">
          <div class="map-wrap">
            <div id="map" aria-label="さいたまの録音地点地図"></div>
            <p class="map-note">Map data © OpenStreetMap contributors / 録音地点はSoundCloudの表記から推定</p>
          </div>
          <aside class="sound-panel" aria-live="polite">
            <img id="sound-photo" src="/assets/img/hero.jpg" alt="" loading="lazy" />
            <div class="panel-body">
              <div id="sound-player" class="player-placeholder">
                <p>地点を選ぶとSoundCloudプレイヤーが表示されます。</p>
              </div>
              <p id="sound-place" class="panel-place">地点を読み込み中</p>
              <h3 id="sound-title">さいたまの音</h3>
              <p id="sound-description"></p>
              <blockquote id="sound-note"></blockquote>
              <div id="sound-tags" class="tag-list" aria-label="タグ"></div>
              <div class="player-controls" aria-label="音源再生オプション">
                <button id="continuous-play" class="mode-button icon-button" type="button" aria-pressed="false" aria-label="連続再生を切り替える">
                  <span class="control-icon" aria-hidden="true">∞</span>
                  <span class="sr-only">連続再生</span>
                </button>
                <button id="prev-sound" class="mode-button icon-button" type="button" disabled aria-label="前の地点へ">
                  <span class="control-icon" aria-hidden="true">◀</span>
                  <span class="sr-only">前の地点へ</span>
                </button>
                <span id="sound-counter" class="sound-counter" aria-live="polite">- / -</span>
                <button id="next-sound" class="mode-button icon-button" type="button" disabled aria-label="次の地点へ">
                  <span class="control-icon" aria-hidden="true">▶</span>
                  <span class="sr-only">次の地点へ</span>
                </button>
              </div>
              <p class="rights-note">SoundCloudの表記をもとに地点情報を整理しています。座標は録音地点説明からの推定です。</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="section notes-section" aria-labelledby="notes-title">
        <div class="section-heading compact">
          <p class="section-kicker">Listening Notes</p>
          <h2 id="notes-title">聴くための短い記録</h2>
        </div>
        <div class="notes-grid">
          <ListeningNotes />
        </div>
      </section>

      <section id="program" class="section muted">
        <div class="section-heading compact">
          <p class="section-kicker">Program</p>
          <h2>今年度の予定</h2>
        </div>
        <div class="timeline">
          <article>
            <time datetime="2026-07-18">2026年7月18日（土）・19日（日）16:00〜19:00</time>
            <div>
              <h3>サウンド・<wbr />コミュニケーション・<wbr /><span class="text-keep">ウォークさいたま2026</span></h3>
              <p>フィールドレコーディングクラブさいたまと歩く、大宮の音風景の探索。同一内容で各日開催するため、参加はどちらか1日をお選びください。集合: まちラボおおみや / 各日定員10名程度 / 参加費1000円（当日払い・小中学生無料）</p>
              <a class="inline-apply" href="https://soundwalk-saitama2026-7.peatix.com/" target="_blank" rel="noopener">参加日を選んで申込む</a>
              <div class="program-detail">
                <p><strong>受付</strong> 15:30〜 / <strong>開始</strong> 16:00</p>
                <p>コミュニケーション・サウンドウォーク（徒歩約1.5km / 約2時間）</p>
                <p><strong>ルート</strong> 大宮駅周辺・大宮一番街商店街〜氷川参道〜武蔵一宮氷川神社・大宮公園</p>
                <p><strong>体験内容</strong> 沈黙して歩く時間、音や風景の記録、参加者同士の共有</p>
              </div>
            </div>
          </article>
          <article>
            <time datetime="2026-09">2026年9月〜12月</time>
            <div>
              <h3>録音ワークショップ</h3>
              <p>街歩きとフィールドレコーディングのワークショップを2回開催予定です。</p>
            </div>
          </article>
          <article>
            <time datetime="2027-03">2027年3月</time>
            <div>
              <h3>成果展示発表会</h3>
              <p>ワークショップで録音した音源や関連資料を展示します。</p>
            </div>
          </article>
        </div>
      </section>

      <section id="join" class="section join-section">
        <div>
          <p class="section-kicker">Join</p>
          <h2>7月18日か19日。どちらか1日、聴くために歩く。</h2>
        </div>
        <div class="join-links">
          <a class="button primary accent" href="https://soundwalk-saitama2026-7.peatix.com/" target="_blank" rel="noopener">参加日を選んで申込む</a>
          <span class="button disabled" aria-disabled="true">録音ワークショップ申込み / 準備中</span>
          <a class="button" href="#program">展示発表会の情報を見る</a>
          <a class="button" href="https://www.instagram.com/fieldrecording_saitama" target="_blank" rel="noopener">Instagramを見る</a>
          <a class="button" href="https://www.facebook.com/groups/800702228957228/" target="_blank" rel="noopener">Facebookグループを見る</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>Field Recording Club Saitama / Soundscape Archive</p>
    </footer>

    <script is:inline src="/assets/vendor/maplibre/maplibre-gl.js"></script>
    <script is:inline src="https://w.soundcloud.com/player/api.js"></script>
    <script is:inline src="/assets/js/main.js?v=20260702-astro"></script>
  </body>
</html>
