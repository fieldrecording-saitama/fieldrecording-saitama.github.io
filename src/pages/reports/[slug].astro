---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports.map((report) => ({
    params: { slug: report.slug },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content } = await report.render();
const pageTitle = `${report.data.title} | フィールドレコーディングクラブさいたま`;
const canonicalUrl = new URL(`/reports/${report.slug}/`, Astro.site).toString();
const formattedDate = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(report.data.date);
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={report.data.description}>
    <meta name="robots" content="index, follow, max-image-preview:large">
    <link rel="canonical" href={canonicalUrl}>
    <meta property="og:site_name" content="フィールドレコーディングクラブさいたま">
    <meta property="og:title" content={report.data.title}>
    <meta property="og:description" content={report.data.description}>
    <meta property="og:type" content="article">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content="https://fieldrecording-saitama.github.io/assets/img/hero-slide-race-stadium.jpg">
    <meta property="og:image:alt" content="大宮周辺を歩くフィールドワークの参加者">
    <meta property="og:locale" content="ja_JP">
    <meta property="article:published_time" content={report.data.date.toISOString()}>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={report.data.title}>
    <meta name="twitter:description" content={report.data.description}>
    <meta name="twitter:image" content="https://fieldrecording-saitama.github.io/assets/img/hero-slide-race-stadium.jpg">
    <meta name="theme-color" content="#24483e">
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/assets/css/style.css">
  </head>
  <body>
    <header class="site-header article-header" aria-label="サイトヘッダー">
      <a class="brand" href="/" aria-label="フィールドレコーディングクラブさいたま ホーム">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>FRCS</span>
      </a>
      <nav class="site-nav" aria-label="主要ナビゲーション">
        <a href="/#about">About</a>
        <a href="/#sound-map">Sound Map</a>
        <a href="/#reports">Reports</a>
        <a href="/#join">Join</a>
      </nav>
    </header>

    <main>
      <article class="article-page">
        <a class="article-back" href="/#reports">Reportsへ戻る</a>
        <p class="section-kicker">Report</p>
        <h1>{report.data.title}</h1>
        <time datetime={report.data.date.toISOString().slice(0, 10)}>{formattedDate}</time>
        <div class="article-body">
          <Content />
        </div>
      </article>
    </main>

    <footer class="site-footer">
      <p>Field Recording Club Saitama / Reports</p>
    </footer>
  </body>
</html>
